From 98f0a659de425724bd2a6b989cafa3e715318a37 Mon Sep 17 00:00:00 2001
From: Andrej Rosano <andrej.rosano@reversec.com>
Date: Tue, 3 Feb 2026 16:09:01 +0100
Subject: [PATCH 1/2] Allow loading TamaGo as BL31

---
 Makefile                                        |  6 ++++++
 .../common/lan969x_bl2_mem_params_desc.c        | 17 ++++++++++++++++-
 .../lan969x/common/lan969x_bl2_setup.c          |  2 ++
 .../lan969x/common/lan969x_bl31_setup.c         |  2 ++
 plat/microchip/lan969x/common/lan969x_tz.c      |  4 ++++
 plat/microchip/lan969x/include/platform_def.h   |  5 +++++
 6 files changed, 35 insertions(+), 1 deletion(-)

diff --git a/Makefile b/Makefile
index c1b799a2d..f31d8eb2f 100644
--- a/Makefile
+++ b/Makefile
@@ -652,6 +652,12 @@ else
 BL2_CPPFLAGS += -DIMAGE_AT_EL1
 endif
 
+ifeq (${TAMAGO_BL31},1)
+BL2_CPPFLAGS += -DTAMAGO_BL31
+BL2_CPPFLAGS += -DTAMAGO_ENTRY_POINT=${TAMAGO_ENTRY_POINT}
+BL2_CPPFLAGS += -DTAMAGO_TEXT_START=${TAMAGO_TEXT_START}
+endif
+
 ifeq (${ARCH},aarch64)
 BL2U_CPPFLAGS += -DIMAGE_AT_EL1
 BL31_CPPFLAGS += -DIMAGE_AT_EL3
diff --git a/plat/microchip/lan969x/common/lan969x_bl2_mem_params_desc.c b/plat/microchip/lan969x/common/lan969x_bl2_mem_params_desc.c
index 8f16d9454..d3ffcc7f1 100644
--- a/plat/microchip/lan969x/common/lan969x_bl2_mem_params_desc.c
+++ b/plat/microchip/lan969x/common/lan969x_bl2_mem_params_desc.c
@@ -26,23 +26,37 @@ static bl_mem_params_node_t bl2_mem_params_descs[] = {
 		SET_STATIC_PARAM_HEAD(ep_info, PARAM_EP,
 				      VERSION_2, entry_point_info_t,
 				      SECURE | EXECUTABLE | EP_FIRST_EXE),
+#if (defined(TAMAGO_BL31))
+		.ep_info.pc = TAMAGO_ENTRY_POINT,
+#else
 		.ep_info.pc = BL31_BASE,
+#endif
 		.ep_info.spsr = SPSR_64(MODE_EL3, MODE_SP_ELX,
 					DISABLE_ALL_EXCEPTIONS),
 		SET_STATIC_PARAM_HEAD(image_info, PARAM_EP,
 				      VERSION_2, image_info_t, IMAGE_ATTRIB_PLAT_SETUP),
+#if (defined(TAMAGO_BL31))
+		.image_info.image_base = TAMAGO_TEXT_START,
+#else
 		.image_info.image_base = BL31_BASE,
+#endif
 		.image_info.image_max_size = BL31_LIMIT - BL31_BASE,
 # if defined(BL32_BASE)
 		.next_handoff_image_id = BL32_IMAGE_ID,
 # else
+
+#if (defined(TAMAGO_BL31))
+		.next_handoff_image_id = INVALID_IMAGE_ID,
+#else
 		.next_handoff_image_id = BL33_IMAGE_ID,
+#endif
+
 # endif
 	},
+#if !(defined(TAMAGO_BL31))
 	/* Fill BL33 related information */
 	{
 		.image_id = BL33_IMAGE_ID,
-
 		SET_STATIC_PARAM_HEAD(ep_info, PARAM_EP,
 				      VERSION_2, entry_point_info_t, NON_SECURE | EXECUTABLE),
 #ifdef PRELOADED_BL33_BASE
@@ -77,6 +91,7 @@ static bl_mem_params_node_t bl2_mem_params_descs[] = {
 		.next_handoff_image_id = INVALID_IMAGE_ID,
 	},
 #endif
+#endif
 };
 
 REGISTER_BL_IMAGE_DESCS(bl2_mem_params_descs)
diff --git a/plat/microchip/lan969x/common/lan969x_bl2_setup.c b/plat/microchip/lan969x/common/lan969x_bl2_setup.c
index a842f3799..f3e5a0f5b 100644
--- a/plat/microchip/lan969x/common/lan969x_bl2_setup.c
+++ b/plat/microchip/lan969x/common/lan969x_bl2_setup.c
@@ -163,7 +163,9 @@ void plat_flush_next_bl_params(void)
 {
 	flush_bl_params_desc();
 
+#if !defined(TAMAGO_BL31)
 	/* Last TZPM settings */
 	VERBOSE("Enable last NS devices\n");
 	lan969x_tz_finish();
+#endif
 }
diff --git a/plat/microchip/lan969x/common/lan969x_bl31_setup.c b/plat/microchip/lan969x/common/lan969x_bl31_setup.c
index 495fed4fb..dbaa4ebe0 100644
--- a/plat/microchip/lan969x/common/lan969x_bl31_setup.c
+++ b/plat/microchip/lan969x/common/lan969x_bl31_setup.c
@@ -250,8 +250,10 @@ void bl31_early_platform_setup2(u_register_t arg0, u_register_t arg1,
 		bl_params = bl_params->next_params_info;
 	}
 
+#if !defined(TAMAGO_BL31)
 	if (bl33_image_ep_info.pc == 0 || bl33_image_base == 0)
 		panic();
+#endif
 }
 
 void bl31_plat_arch_setup(void)
diff --git a/plat/microchip/lan969x/common/lan969x_tz.c b/plat/microchip/lan969x/common/lan969x_tz.c
index 930436ee8..840ee6ee9 100644
--- a/plat/microchip/lan969x/common/lan969x_tz.c
+++ b/plat/microchip/lan969x/common/lan969x_tz.c
@@ -37,6 +37,7 @@ static const lan969x_tcreg_t hss_rules[] = {
 	{ 0, TZC_REGION_S_RDWR, PLAT_ARM_TZC_NS_DEV_ACCESS, }
 };
 
+#if !defined(TAMAGO_BL31)
 static void setup_ns_access(uintptr_t gpv, uintptr_t tzpm)
 {
 	/* Allow S+NS access to these devices */
@@ -47,6 +48,7 @@ static void setup_ns_access(uintptr_t gpv, uintptr_t tzpm)
 	mmio_write_32(GPV_SECURITY_APB_CSS2(gpv), BIT(0)); /* OTP */
 	mmio_write_32(GPV_SECURITY_APB_MAIN3(gpv), BIT(2)|BIT(3)); /* TIMERS, WDT */
 }
+#endif
 
 void lan969x_tzc_configure(uintptr_t tzc_base, const lan969x_tcreg_t *regions, size_t nregs)
 {
@@ -83,6 +85,7 @@ void lan969x_tz_init(void)
 {
 	INFO("Configuring TrustZone\n");
 
+#if !defined(TAMAGO_BL31)
 	/*
 	 * Enable TZPM for NS transactions, Otherwise all are treated
 	 * as Secure transactions in CPU subsystem
@@ -113,6 +116,7 @@ void lan969x_tz_init(void)
 					MATRIX_SRTOP(1, MATRIX_SRTOP_VALUE_1M),
 					MATRIX_SASPLIT(0, MATRIX_SRTOP_VALUE_1M),
 					MATRIX_LANSECH_NS(0));
+#endif
 
 	/* TZC: DDR accesess through CSS (128bit) */
 	lan969x_tzc_configure(LAN969X_TZC_CSS_BASE, css_rules, ARRAY_SIZE(css_rules));
diff --git a/plat/microchip/lan969x/include/platform_def.h b/plat/microchip/lan969x/include/platform_def.h
index 04c52d2b6..0a22eee69 100644
--- a/plat/microchip/lan969x/include/platform_def.h
+++ b/plat/microchip/lan969x/include/platform_def.h
@@ -85,8 +85,13 @@
 /*
  * BL31
  */
+#if defined(TAMAGO_BL31)
+#define BL31_BASE		LAN969X_DDR_BASE
+#define BL31_SIZE		SIZE_M(32)
+#else
 #define BL31_BASE		(LAN969X_SRAM_BASE + SIZE_M(1))
 #define BL31_SIZE		SIZE_K(128)
+#endif
 #define BL31_LIMIT		(BL31_BASE + BL31_SIZE)
 
 /* NS image */
-- 
2.53.0

